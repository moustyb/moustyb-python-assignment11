# 1. Virtual Environments
# We ignore these because they contain thousands of downloaded package files 
# that are specific to your local computer. Others can recreate it using requirements.txt.
.venv/
venv/
env/

# 2. Python Compiled Files
# Python creates these automatically when running code. They are not needed in GitHub.
__pycache__/
*.py[cod]
*$py.class

# 3. IDE and Editor Files
# Hides your personal VS Code or PyCharm settings so they don't clutter the repo.
.vscode/
.idea/
*.swp

# 4. Operating System Files
# Hides hidden files created by Mac or Windows that aren't part of your code.
.DS_Store
Thumbs.db

# 5. Distribution / Packaging
# Ignore build folders if you ever package your code.
*.egg-info/
dist/
build/
